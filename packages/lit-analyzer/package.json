{
	"name": "@jackolope/lit-analyzer",
	"version": "3.2.1",
	"description": "CLI that type checks bindings in lit-html templates",
	"author": "runem",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/JackRobards/lit-analyzer.git"
	},
	"keywords": [
		"lit-html",
		"lit",
		"lit-element",
		"javascript",
		"typescript",
		"web components",
		"web",
		"components",
		"tagged",
		"template"
	],
	"bin": {
		"lit-analyzer": "cli.mjs"
	},
	"scripts": {
		"build": "wireit",
		"prepublishOnly": "pnpm test",
		"eslint": "eslint src",
		"test": "wireit",
		"test:ava": "wireit",
		"test:all": "pnpm test",
		"test:watch": "ava --watch --color",
		"check-version": "wireit"
	},
	"wireit": {
		"build": {
			"command": "tsc --build --pretty",
			"files": [
				"src/**/*",
				"tsconfig.json",
				"../../tsconfig.json"
			],
			"output": [
				"lib",
				"test",
				"scripts",
				"index.js",
				"index.d.ts",
				"index.d.ts.map",
				".tsbuildinfo"
			],
			"clean": "if-file-deleted"
		},
		"test": {
			"dependencies": [
				"test:ava",
				"check-version"
			]
		},
		"test:ava": {
			"dependencies": [
				"build"
			],
			"command": "ava --color",
			"output": [],
			"files": [
				"package.json"
			]
		},
		"check-version": {
			"dependencies": [
				"build"
			],
			"files": [
				"package.json",
				"scripts/check-version.js"
			],
			"command": "node scripts/check-version.js"
		}
	},
	"main": "index.js",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"default": "./index.js"
		}
	},
	"files": [
		"/lib/",
		"index.js",
		"index.d.ts",
		"index.d.ts.map",
		"cli.mjs"
	],
	"dependencies": {
		"@jackolope/web-component-analyzer": "^4.0.4",
		"@vscode/web-custom-data": "^0.6.3",
		"chalk": "^5.6.2",
		"didyoumean2": "7.0.4",
		"fast-glob": "^3.2.11",
		"parse5": "8.0.1",
		"ts-simple-type": "~2.0.0-next.0",
		"vscode-css-languageservice": "6.3.10",
		"vscode-html-languageservice": "5.6.2"
	},
	"devDependencies": {
		"@types/node": "^24.12.0",
		"ava": "^7.0.0",
		"tslib": "^2.0.0",
		"typescript": "~5.8.3",
		"typescript-5.4": "npm:typescript@~5.4.0",
		"typescript-5.5": "npm:typescript@~5.5.0",
		"typescript-5.6": "npm:typescript@~5.6.0",
		"typescript-5.7": "npm:typescript@~5.7.0",
		"typescript-5.8": "npm:typescript@~5.8.0",
		"vscode-languageserver-types": "^3.17.5",
		"wireit": "^0.14.12"
	},
	"ava": {
		"cache": true,
		"timeout": "200s",
		"extensions": [
			"js"
		],
		"snapshotDir": "test/snapshots/results",
		"files": [
			"test/**/*.js",
			"!test/helpers/**/*"
		]
	},
	"contributors": [
		{
			"name": "Rune Mehlsen",
			"url": "https://twitter.com/runemehlsen",
			"img": "https://avatars2.githubusercontent.com/u/5372940?s=460&v=4"
		},
		{
			"name": "Andreas Mehlsen",
			"url": "https://twitter.com/andreasmehlsen",
			"img": "https://avatars1.githubusercontent.com/u/6267397?s=460&v=4"
		},
		{
			"name": "You?",
			"img": "https://ui-avatars.com/api/?name=You&background=random&size=100",
			"url": "https://github.com/JackRobards/lit-analyzer/blob/main/CONTRIBUTING.md"
		}
	],
	"engines": {
		"node": ">=20"
	},
	"type": "commonjs"
}
